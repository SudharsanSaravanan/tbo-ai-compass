# Frontend Environment Variables

# Token server URL — served by agent/token_server.py on port 8765
# VoicePlanView.tsx line 36: import.meta.env.VITE_TOKEN_API || "http://localhost:8765"
VITE_TOKEN_API=your_vite_token_api

# LiveKit WebSocket URL — optional, token server returns wsUrl automatically
# VoicePlanView.tsx line 37: import.meta.env.VITE_LIVEKIT_WS || ""
VITE_LIVEKIT_WS=your_vite_livekit_ws

# OpenWeather API Key — used by weatherService.ts
# Not included in your provided keys — leave blank or ask teammate if needed
VITE_WEATHER_API_KEY=your_weather_api_key
VITE_MAPBOX_TOKEN=your_vite_mapbox_token
VITE_TAVILY_KEY=your_tavily_key